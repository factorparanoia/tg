{
  "name": "midnight-ai",
  "version": "1.0.0",
  "description": "Midnight AI — Personal AI Agent for Telegram",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.15.0",
    "telegraf": "^4.16.3",
    "openai": "^4.47.1",
    "ioredis": "^5.3.2",
    "node-cron": "^3.0.3",
    "pdf-parse": "^1.1.1",
    "mammoth": "^1.7.2",
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "winston": "^3.13.0",
    "date-fns": "^3.6.0",
    "chrono-node": "^2.7.6",
    "mathjs": "^13.0.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "p-queue": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.4",
    "@types/uuid": "^10.0.0",
    "@types/mathjs": "^9.4.2",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^9.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "prisma": "^5.15.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
